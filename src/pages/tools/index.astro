---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title="Free Tools for China Sourcing"
      description="Free tools for foreign buyers sourcing from China — email templates, calculators, and guides to make importing easier."
    />
  </head>
  <body>
    <Header />
    <main class="tools-main">
      <div class="tools-header">
        <h1>Free Sourcing Tools</h1>
        <p>Practical tools for foreign buyers working with Chinese suppliers.</p>
      </div>

      <div class="tools-grid">
        <a href="/tools/email-writer" class="tool-card">
          <span class="tool-icon">✉️</span>
          <div class="tool-info">
            <h2>Chinese Supplier Email Writer</h2>
            <p>Generate professional Chinese emails for your suppliers — price inquiries, counter offers, complaints, sample requests, and more. 8 ready-to-use templates.</p>
            <span class="tool-tag">Free · No signup</span>
          </div>
        </a>
      </div>

      <div class="coming-soon">
        <h2>Coming Soon</h2>
        <div class="soon-grid">
          <div class="soon-card">
            <span>🧮</span>
            <strong>Landed Cost Calculator</strong>
            <p>Calculate total cost including product, freight, duties, and fees.</p>
          </div>
          <div class="soon-card">
            <span>📦</span>
            <strong>CBM & Weight Calculator</strong>
            <p>Calculate volumetric weight and shipping costs for your shipment.</p>
          </div>
          <div class="soon-card">
            <span>🔍</span>
            <strong>1688 Keyword Translator</strong>
            <p>Translate product names to Chinese for searching on 1688.com.</p>
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .tools-main {
    max-width: 900px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 5rem;
  }
  .tools-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .tools-header h1 {
    font-size: 2rem;
    color: #0f172a;
    margin-bottom: 0.5rem;
  }
  .tools-header p { color: #64748b; font-size: 1rem; }

  .tools-grid { display: flex; flex-direction: column; gap: 1rem; margin-bottom: 3rem; }

  .tool-card {
    display: flex;
    align-items: flex-start;
    gap: 1.5rem;
    background: #fff;
    border: 2px solid #1d4ed8;
    border-radius: 14px;
    padding: 1.75rem;
    text-decoration: none;
    transition: box-shadow 0.15s, transform 0.15s;
  }
  .tool-card:hover { box-shadow: 0 6px 24px rgba(29,78,216,0.12); transform: translateY(-2px); }
  .tool-icon { font-size: 2.5rem; flex-shrink: 0; }
  .tool-info h2 { font-size: 1.2rem; color: #0f172a; margin: 0 0 0.5rem; }
  .tool-info p { color: #475569; font-size: 0.9rem; line-height: 1.6; margin: 0 0 0.75rem; }
  .tool-tag {
    display: inline-block;
    background: #dbeafe;
    color: #1d4ed8;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
  }

  .coming-soon h2 { font-size: 1.1rem; color: #64748b; margin-bottom: 1rem; }
  .soon-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .soon-card {
    background: #f8fafc;
    border: 1px dashed #cbd5e1;
    border-radius: 12px;
    padding: 1.25rem;
  }
  .soon-card span { font-size: 1.75rem; display: block; margin-bottom: 0.5rem; }
  .soon-card strong { display: block; color: #334155; font-size: 0.9rem; margin-bottom: 0.35rem; }
  .soon-card p { color: #94a3b8; font-size: 0.8rem; margin: 0; line-height: 1.5; }

  @media (max-width: 640px) {
    .tool-card { flex-direction: column; gap: 1rem; }
    .soon-grid { grid-template-columns: 1fr; }
  }
</style>
