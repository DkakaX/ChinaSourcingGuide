---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<html lang="en">
  <head>
    <BaseHead
      title="Contact Us"
      description="Have a question about sourcing from China? Get in touch with the China Source Hub team."
    />
  </head>
  <body>
    <Header />
    <main class="page-main">
      <h1>Contact Us</h1>
      <p class="lead">
        Have a question about sourcing from China, a topic you'd like us to cover, or spotted
        something inaccurate in one of our guides? We'd love to hear from you.
      </p>

      <div class="contact-box">
        <div class="contact-item">
          <span class="contact-icon">✉️</span>
          <div>
            <p class="contact-label">Email</p>
            <a href="mailto:dkoydyx@cozysheep.tech" class="contact-link">dkoydyx@cozysheep.tech</a>
          </div>
        </div>
        <p class="contact-note">We typically respond within 1–2 business days.</p>
      </div>

      <div class="topics">
        <h2>What can you contact us about?</h2>
        <ul>
          <li>Questions about sourcing from China or using 1688 / Alibaba</li>
          <li>Suggesting a topic you'd like us to cover</li>
          <li>Reporting an inaccuracy in one of our guides</li>
          <li>Partnership or advertising inquiries</li>
        </ul>
      </div>
    </main>
    <Footer />
  </body>
</html>

<style>
  .page-main {
    max-width: 640px;
    margin: 2rem auto;
    padding: 0 1.5rem 4rem;
  }
  h1 { font-size: 2rem; color: #0f172a; margin-bottom: 1rem; }
  .lead { color: #334155; line-height: 1.75; margin-bottom: 2rem; }
  .contact-box {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.75rem;
    margin-bottom: 2.5rem;
  }
  .contact-item { display: flex; align-items: center; gap: 1rem; }
  .contact-icon { font-size: 1.75rem; }
  .contact-label { font-size: 0.8rem; color: #64748b; margin: 0 0 0.15rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .contact-link { font-size: 1.1rem; font-weight: 600; color: #1d4ed8; text-decoration: none; }
  .contact-link:hover { text-decoration: underline; }
  .contact-note { margin: 1rem 0 0; font-size: 0.875rem; color: #64748b; }
  .topics h2 { font-size: 1.25rem; color: #0f172a; margin-bottom: 0.75rem; }
  .topics ul { padding-left: 1.25rem; color: #334155; line-height: 1.9; }
</style>
