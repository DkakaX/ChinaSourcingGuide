---
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

<div class:list={['author-box', { compact }]}>
  <div class="author-avatar">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none" aria-hidden="true">
      <circle cx="20" cy="20" r="20" fill="#e2e8f0"/>
      <circle cx="20" cy="16" r="7" fill="#94a3b8"/>
      <ellipse cx="20" cy="36" rx="12" ry="8" fill="#94a3b8"/>
    </svg>
  </div>
  <div class="author-info">
    <p class="author-name">China Source Hub</p>
    {!compact && (
      <p class="author-bio">
        We've been sourcing products from China since 2018 — from 1688 factories in Guangzhou to
        the Yiwu wholesale market. Everything on this site is based on real buying experience,
        not secondhand research.
      </p>
    )}
  </div>
</div>

<style>
  .author-box {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem 1.5rem;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    margin: 2rem 0;
  }
  .author-box.compact {
    padding: 0.75rem 1rem;
    margin: 1rem 0;
  }
  .author-avatar svg {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: 50%;
  }
  .compact .author-avatar svg { width: 36px; height: 36px; }
  .author-name {
    font-weight: 700;
    color: #1e293b;
    margin: 0 0 0.4rem;
    font-size: 0.95rem;
  }
  .author-bio {
    color: #64748b;
    font-size: 0.875rem;
    line-height: 1.6;
    margin: 0;
  }
</style>
